{
  "manifest_version": 3,
  "name": "CPCC Deck Optimizer",
  "version": "0.0.3",
  "description": "からぱり☆カードコレクション! 用の最適デッキ計算補助",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://korimizu.com/CPCC/*",
        "https://april.colorfulparty.jp/CPCC/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-gacha-bridge.js"
      ],
      "matches": [
        "https://korimizu.com/*",
        "https://april.colorfulparty.jp/*"
      ]
    }
  ]
}
